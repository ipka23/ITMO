print_greet:

   lui   t4, %hi(stop_symbol)
   addi  t4, t4, %lo(stop_symbol)
   addi  t4, t4, 1
   lw t4, 0(t4)

   lui   t5, %hi(end_symbol)
   addi  t5, t5, %lo(end_symbol)
   addi  t5, t5, 1
   lw t5, 0(t5)


handle_word:


    beq t4, t2, end

    addi     t1, t1, 1 ; ptr++

   j handle_word

end:
    lb t2, 0(t5)
    sb t2, 0(t0)
    halt

