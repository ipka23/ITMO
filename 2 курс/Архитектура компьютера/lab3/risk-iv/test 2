    .data
.org 0x100
stop_symbol:     .byte 1, '\n'
end_symbol:     .byte 1, '!'
input_addr:      .word  0x80
output_addr:     .word  0x84

    .text
_start:
    lui   t0, %hi(output_addr)
    addi  t0, t0, %lo(output_addr)
    lw t0, 0(t0)

    lui   t1, %hi(input_addr)
    addi  t1, t1, %lo(input_addr)
    lw t1, 0(t1)

   lui   t4, %hi(stop_symbol)
   addi  t4, t4, %lo(stop_symbol)
   addi  t4, t4, 1
   lb t4, 0(t4)

   lui   t5, %hi(end_symbol)
   addi  t5, t5, %lo(end_symbol)
   addi  t5, t5, 1
   lb t5, 0(t5)

input:
    lb t2, 0(t1)
    beq t2, t4, end
    sb t2, 0(t0)
    j input
end:
    sb t5, 0(t0)
    halt


